generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Profile {
  id          String   @id @default(cuid())
  fullName    String   @default("Temuulen")
  headline    String   @default("Web Developer • Програм хангамжийн оюутан")
  subheadline String   @default("Их Засаг ОУИС-ийн КПХ-322 бүлгийн 3-р курсын оюутан")
  bio         String   @default("Цэвэрхэн дизайнтай, ойлгомжтой, responsive веб сайт хөгжүүлэхэд төвлөрдөг.")
  email       String   @default("tk20060320@gmail.com")
  phone       String   @default("+976 95124438")
  location    String   @default("3,4-р хороолол, Улаанбаатар")
  githubUrl   String   @default("https://github.com/Online6510")
  linkedinUrl String   @default("https://www.facebook.com/search/top?q=Erdenesaruul%20Temuulen")
  instagramUrl String  @default("https://www.facebook.com/search/top?q=Erdenesaruul%20Temuulen")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Project {
  id          String   @id @default(cuid())
  title       String
  description String
  tags        String   @default("[]")
  gradient    String   @default("from-blue-500/10 to-cyan-500/10")
  accentColor String   @default("bg-blue-500")
  url         String?
  imageUrl    String?
  isFeatured  Boolean  @default(true)
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model SkillCategory {
  id        String   @id @default(cuid())
  name      String
  icon      String   @default("code")
  sortOrder Int      @default(0)
  skills    Skill[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Skill {
  id         String        @id @default(cuid())
  name       String
  level      Int
  sortOrder  Int           @default(0)
  categoryId String
  category   SkillCategory @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  createdAt  DateTime      @default(now())
  updatedAt  DateTime      @updatedAt
}

model Message {
  id        String   @id @default(cuid())
  name      String
  email     String
  subject   String?
  message   String
  status    String   @default("unread")
  ipAddress String?
  userAgent String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
